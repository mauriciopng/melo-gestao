# Banco de dados Turso — crie em https://turso.tech
TURSO_DATABASE_URL=libsql://seu-banco.turso.io
TURSO_AUTH_TOKEN=seu_token_aqui

# PIN de acesso ao app (ex: 1234)
MELO_PIN=sua_senha_aqui

# Notificações push — gere com: node scripts/generate-vapid.mjs
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:seuemail@exemplo.com
